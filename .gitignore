cat > .gitignore << 'EOF'
# Virtual environment
venv/
.venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Data files (large, not committed)
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.zip
data/processed/*.csv

# Model artifacts
checkpoints/*.pt
checkpoints/*.pth
models/saved_models/
*.bin
*.onnx

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Logs
*.log
logs/

# HuggingFace cache
.cache/

# Pytest
.pytest_cache/

# SQLite databases
*.db
*.sqlite
*.sqlite3

# Secrets
.env
*.env
EOF